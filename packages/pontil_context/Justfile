_default:
    just --list

# Run tests for pontil_context with both targets
@test:
    gleam test --target erlang
    gleam test --target javascript

# Build pontil_context with both targets
@build:
    gleam build --target erlang
    gleam build --target javascript

# Lint pontil_context
@lint:
    gleam run -m glinter

# Build docs for pontil_context
@docs:
    gleam docs build

# Open pontil_context docs in the browser
@open-docs: docs
    open build/dev/docs/pontil_context/index.html

# Clean all build artifacts
@clean:
    rm -rf build
