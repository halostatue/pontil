_default:
    just --list

# Run tests for pontil_core with both targets
@test:
    gleam test --target erlang
    gleam test --target javascript

# Build pontil_core with both targets
@build:
    gleam build --target erlang
    gleam build --target javascript

# Lint pontil_core
@lint:
    gleam run -m glinter

# Build docs for pontil_core
@docs:
    gleam docs build

# Open pontil_core docs in the browser
@open-docs: docs
    open build/dev/docs/pontil_core/index.html

# Clean all build artifacts
@clean:
    rm -rf build
